# Copy this file to .env and fill in your own values

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/rankora

# JWT Auth (generate a strong random secret, e.g. run: openssl rand -hex 32)
JWT_SECRET=your-strong-random-secret-here

# OpenAI
OPENAI_API_KEY=sk-...

# PayPal (get these from developer.paypal.com)
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id
VITE_PAYPAL_PRO_PLAN_ID=your-paypal-pro-plan-id
VITE_PAYPAL_PREMIUM_PLAN_ID=your-paypal-premium-plan-id

# Email (for feedback form, e.g. Gmail SMTP)
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password

# Admin
ADMIN_EMAIL=you@gmail.com

# Optional
LOG_LEVEL=info
NODE_ENV=development
